                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path
                                        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                                </svg>
                            </div>
                            <div class="contact-method__content">
                                <span class="contact-method__label">WhatsApp</span>
                                <span class="contact-method__value">Enviar mensaje</span>
                            </div>
                        </a>
                    </div>

                    <div class="contact__hours">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>Lunes a Viernes: 9:00 - 14:00</span>
                    </div>
                </div>

                <form class="contact__form" id="contactForm" action="https://formsubmit.co/tmmcartagena@hotmail.com"
                    method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="_subject" value="Nuevo Mensaje Web TMM">
                    <input type="hidden" name="_captcha" value="false">
                    <input type="hidden" name="_template" value="table">

                    <div class="form-group">
                        <label for="nombre" class="form-label">Nombre completo <span class="required">*</span></label>
                        <input type="text" id="nombre" name="nombre" class="form-input" required>
                        <span class="form-error" id="nombreError"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="telefono" class="form-label">Teléfono <span class="required">*</span></label>
                            <input type="tel" id="telefono" name="telefono" class="form-input" required>
                            <span class="form-error" id="telefonoError"></span>
                        </div>

                        <div class="form-group">
                            <label for="email" class="form-label">Email <span class="required">*</span></label>
                            <input type="email" id="email" name="email" class="form-input" required>
                            <span class="form-error" id="emailError"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="tipoEspacio" class="form-label">Tipo de espacio <span
                                class="required">*</span></label>
                        <select id="tipoEspacio" name="tipoEspacio" class="form-input" required>
                            <option value="">Selecciona una opción</option>
                            <option value="vivienda">Vivienda particular</option>
                            <option value="negocio">Negocio/Local</option>
                            <option value="comunidad">Comunidad de propietarios</option>
                            <option value="industrial">Espacio industrial</option>
                        </select>
                        <span class="form-error" id="tipoEspacioError"></span>
                    </div>

                    <div class="form-group">
                        <label for="problema" class="form-label">Describe el problema <span
                                class="required">*</span></label>
                        <textarea id="problema" name="problema" class="form-input" rows="4"
                            placeholder="Ej: He visto cucarachas en la cocina por las noches, he encontrado excrementos de roedores en el garaje..."
                            required></textarea>
                        <span class="form-error" id="problemaError"></span>
                    </div>



                    <div class="form-group form-group--checkbox">
                        <label class="checkbox-label">
                            <input type="checkbox" id="privacidad" name="privacidad" required>
                            <span class="checkbox-text">Acepto la <a href="#" class="link">política de privacidad</a> y
                                el tratamiento de mis datos <span class="required">*</span></span>
                        </label>
                        <span class="form-error" id="privacidadError"></span>
                    </div>

                    <button type="submit" class="btn btn--primary btn--large btn--full">Solicitar Presupuesto
                        Gratuito</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer__content">
                <div class="footer__section">
                    <div class="footer__logo">
                        <span class="logo-text">TMM<span class="logo-subtitle">Control de Plagas</span></span>
                    </div>
                    <p class="footer__description">Soluciones profesionales de control de plagas en Murcia y provincia.
                    </p>
                </div>

                <div class="footer__section">
                    <h3 class="footer__heading">Contacto</h3>
                    <address class="footer__address">
                        <p><strong>TMM Control Integral de Plagas, S.L.</strong></p>
                        <p>La Unión, Murcia 30360</p>
                        <p>NIF: B00000000X</p>
                        <p>Tel: <a href="tel:+34663045041">663 045 041</a></p>
                        <p>Email: <a href="mailto:tmmcartagena@hotmail.com">tmmcartagena@hotmail.com</a></p>
                    </address>
                </div>

                <div class="footer__section">
                    <h3 class="footer__heading">Servicios</h3>
                    <ul class="footer__links">
                        <li><a href="#servicios">Control de Insectos</a></li>
                        <li><a href="#servicios">Control de Roedores</a></li>
                        <li><a href="#servicios">Desinsectación</a></li>
                        <li><a href="#servicios">Fumigación</a></li>
                    </ul>
                </div>

                <div class="footer__section">
                    <h3 class="footer__heading">Legal</h3>
                    <ul class="footer__links">
                        <li><a href="#">Aviso Legal</a></li>
                        <li><a href="#">Política de Privacidad</a></li>
                        <li><a href="#">Política de Cookies</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer__bottom">
                <p>&copy; 2026 TMM Control Integral de Plagas, S.L. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="script.js"></script>
</body>

