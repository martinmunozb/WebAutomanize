    <!-- Services Section -->
    <section class="services" id="servicios">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Servicios Especializados</h2>
                <p class="section-subtitle">Tratamientos específicos diseñados para cada tipo de plaga con resultados
                    verificables y duraderos.</p>
            </div>

            <div class="services__grid">
                <!-- Service 1: Insects -->
                <article class="service-card">
                    <div class="service-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path
                                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                    </div>
                    <h3 class="service-card__title">Control de Insectos</h3>
                    <p class="service-card__problem">Eliminamos cucarachas, hormigas, arañas, mosquitos y otros insectos
                        rastreros y voladores de forma definitiva.</p>
                    <div class="service-card__includes">
                        <h4>Qué incluye:</h4>
                        <ul>
                            <li>Inspección de puntos de entrada y anidación</li>
                            <li>Tratamiento con productos específicos según especie</li>
                            <li>Barrera preventiva perimetral de larga duración</li>
                        </ul>
                    </div>
                    <div class="service-card__when">
                        <strong>Cuándo aplicarlo:</strong> Presencia visible, rastros de actividad o prevención
                        estacional.
                    </div>
                    <div class="service-card__results">
                        <strong>Resultado:</strong> Eliminación en 48-72h con protección residual de 3-6
                        meses.
                    </div>
                </article>

                <!-- Service 2: Rodents -->
                <article class="service-card service-card--popular">
                    <span class="card-badge">Más Demandado</span>
                    <div class="service-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path
                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <h3 class="service-card__title">Control de Roedores</h3>
                    <p class="service-card__problem">Solución integral contra ratas, ratones y otros roedores en
                        viviendas y negocios con métodos seguros.</p>
                    <div class="service-card__includes">
                        <h4>Qué incluye:</h4>
                        <ul>
                            <li>Identificación de rutas de tránsito y madrigueras</li>
                            <li>Colocación estratégica de cebos y estaciones</li>
                            <li>Sellado de puntos de acceso (asesoramiento incluido)</li>
                        </ul>
                    </div>
                    <div class="service-card__when">
                        <strong>Cuándo aplicarlo:</strong> Ruidos nocturnos, excrementos, daños en cables o
                        envases mordidos.
                    </div>
                    <div class="service-card__results">
                        <strong>Resultado:</strong> Actividad eliminada en 7-14 días con seguimiento
                        preventivo.
                    </div>
                </article>

                <!-- Service 3: Desinsectación -->
                <article class="service-card">
                    <div class="service-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path
                                d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                        </svg>
                    </div>
                    <h3 class="service-card__title">Desinsectación Profesional</h3>
                    <p class="service-card__problem">Tratamiento completo para negocios que requieren certificación
                        sanitaria</p>
                    <div class="service-card__includes">
                        <h4>Qué incluye:</h4>
                        <ul>
                            <li>Pulverización, nebulización o gel según necesidad</li>
                            <li>Productos certificados con fichas de seguridad</li>
                            <li>Aplicación fuera de horario comercial si se requiere</li>
                            <li>Certificado de tratamiento para inspecciones</li>
                        </ul>
                    </div>
                    <div class="service-card__when">
                        <strong>Cuándo aplicarlo:</strong> Mantenimiento periódico, auditorías sanitarias o
                        certificaciones APPCC
                    </div>
                    <div class="service-card__results">
                        <strong>Resultado:</strong> Certificado oficial + control efectivo sin interrumpir operaciones
                    </div>
                </article>

                <!-- Service 4: Fumigación -->
                <article class="service-card">
                    <div class="service-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
