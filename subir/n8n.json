      "name": "Merge Resumen",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [3568, 1400]
    },
    {
      "parameters": {
        "jsCode": "const datos = $('Merge Carpeta Mes').first().json;\n\nconst gastosItems = $('Buscar Gastos Pendientes Inmueble').all().map(i => i.json);\nconst pagosItems  = $('Buscar Pagos Inmueble').all().map(i => i.json);\n\nconst gastosPendientes = Array.isArray(gastosItems[0]) ? gastosItems[0] : gastosItems.filter(g => g.tipo_pago);\nconst pagosList        = Array.isArray(pagosItems[0])  ? pagosItems[0]  : pagosItems.filter(p => p.importe !== undefined);\n\nconst totalGastos = gastosPendientes.reduce((s, g) => s + (parseFloat(g.importe) || 0), 0);\nconst totalPagos  = pagosList.reduce((s, p) => s + (parseFloat(p.importe) || 0), 0);\nconst balance     = totalPagos - totalGastos;\n\nconst TIPOS = {\n  'hipoteca':'Hipoteca','seguro-vida':'Seguro Vida','seguro-hogar':'Seguro Hogar',\n  'seguro-impago':'Seguro Impago','comunidad':'Comunidad','derramas':'Derramas',\n  'ibi':'IBI','agua':'Agua','luz':'Luz','limpieza':'Limpieza','alarma':'Alarma','wifi':'Wifi'\n};\nconst fmt = n => n.toFixed(2).replace('.', ',') + '€';\n\nconst lineas = gastosPendientes.map(g => {\n  const nombre  = TIPOS[g.tipo_pago] || g.tipo_pago;\n  const periodo = g.periodo ? g.periodo.slice(0,7).split('-').reverse().join('/') : '';\n  return `• ${nombre}${periodo ? ' · ' + periodo : ''}: ${fmt(parseFloat(g.importe||0))}`;\n}).join('\\n');\n\nconst mensaje = [\n  `🏠 *${datos.nombreInmueble}* · Resumen`,\n  '',\n  gastosPendientes.length\n    ? `📋 *Gastos pendientes (${gastosPendientes.length}):*\\n${lineas}`\n    : '✅ No hay gastos pendientes',\n  '',\n  `💸 *Total gastos pendientes:* ${fmt(totalGastos)}`,\n  `💵 *Total ingresos recibidos:* ${fmt(totalPagos)}`,\n  `${balance >= 0 ? '✅' : '⚠️'} *Balance:* ${fmt(balance)}`\n].join('\\n');\n\nconst tel = datos.gestorTelefono || '';\nconst to  = tel ? (tel.startsWith('+') ? tel : '+34' + tel.replace(/^0+/, '')) : '';\n\nreturn [{ json: { mensaje, to } }];"
      },
      "id": "b2000004-0004-0004-0004-000000000004",
      "name": "Calcular Balance",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3792, 1400]
