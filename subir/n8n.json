        {
            "id": "preparar-datos-drive",
            "name": "Preparar Datos Drive",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                900,
                620
            ],
            "parameters": {
                "jsCode": "const webhookData = $('Webhook POST gastos-submit').first();\nconst body        = webhookData.json.body;\nconst inquilino   = $('Validar Token').first().json[0];\n\nconst CARPETAS = {\n  'hipoteca':      '167rSr7ALC52FQz4NNtP4Yh33eBO0SgAN',\n  'seguro-vida':   '1bWe2D62QFgye0v5L5-ZnsLMmc88qVw9F',\n  'seguro-hogar':  '1IH6RrytwijxRYzrtBZzfnRqaFINDkF13',\n  'seguro-impago': '1vzIDLzJ5yrtg35NcViESA3V2EwlCp5O_',\n  'comunidad':     '1WgsRy0sKpcP9t45Mc-VDBY8y9x18vHl5',\n  'derramas':      '1RJsoEO-S3_be__UgsjR6CXSwRdVdzZP4',\n  'ibi':           '1jJUBl7OzilTTOJ8uJVQM04ryb03iMZkc',\n  'agua':          '1oSYS7AwF-l9l5Z8cO9GRLKX02R19LWli',\n  'luz':           '1gzCL7LAiCmhBaQbsUglt9F4xdFxhNWrD',\n  'limpieza':      '1z0yIN-83yHJBxLtBHMAu_ZVHqsDO5V2s',\n  'alarma':        '1-v5zouk7OuZeuDn7T6ialZL0vADjir3w',\n  'wifi':          '1-W05CTSlaErPraimwsFTJOI0Oc6pLX57'\n};\n\nconst tipo        = (body.tipo || 'otros').toLowerCase();\nconst carpetaId   = CARPETAS[tipo] || '1i0iC9eoR-J1R69MLotuth-R1aHilbril';\nconst inquilinoId = inquilino.id;\n\n// Periodo viene como MM-YYYY → convertir a YYYY-MM para Supabase\nconst periodoRaw = body.periodo || '';\nlet periodoISO = '';\nif (periodoRaw.includes('-')) {\n  const parts = periodoRaw.split('-');\n  if (parts[0].length === 2) {\n    // formato MM-YYYY\n    periodoISO = `${parts[1]}-${parts[0]}-01`;\n  } else {\n    // ya viene YYYY-MM\n    periodoISO = `${periodoRaw}-01`;\n  }\n}\n\n// Nombre del archivo: INQUILINOID-TIPO-YYYY-MM.ext\nconst binaryData   = webhookData.binary?.archivo;\nconst mimeType     = binaryData?.mimeType || 'image/jpeg';\nconst originalName = binaryData?.fileName || 'justificante.jpg';\nconst ext          = originalName.split('.').pop() || 'jpg';\nconst periodoLabel = periodoRaw.replace('-', '-');\nconst nombreArchivo = `${inquilinoId}-${tipo}-${periodoLabel}.${ext}`;\n\nfunction pad(n, w) { return String(n).padStart(w, '0'); }\nconst date    = new Date().toISOString().slice(0,10).replace(/-/g,'');\nconst rand    = Math.floor(Math.random() * 10000);\nconst gastoId = `GASTO-${date}-${pad(rand,4)}`;\n\nreturn [{\n  json: {\n    gastoId, inquilinoId,\n    clienteId:    inquilino.cliente_id,\n    tipo, periodoISO,\n    importe:      parseFloat(body.importe) || 0,\n    carpetaId, nombreArchivo, mimeType\n  },\n  binary: webhookData.binary\n}];"
            }
        },
