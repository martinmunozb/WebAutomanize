      "parameters": {
        "jsCode": "const entry = $input.first().json;\nconst msg   = entry.messages?.[0] || entry;\nconst from  = msg.from  || entry.from  || '';\nconst type  = msg.type  || entry.type  || '';\nconst texto = msg.text?.body || msg.body || '';\nlet replyId = '', replyTitle = '';\nif (type === 'interactive') {\n  if (msg.interactive?.type === 'list_reply') {\n    replyId    = msg.interactive.list_reply?.id    || '';\n    replyTitle = msg.interactive.list_reply?.title || '';\n  } else if (msg.interactive?.type === 'button_reply') {\n    replyId    = msg.interactive.button_reply?.id    || '';\n    replyTitle = msg.interactive.button_reply?.title || '';\n  }\n}\nreturn [{ json: { from, type, texto, replyId, replyTitle } }];"
      },
