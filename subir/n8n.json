    {
      "parameters": {
        "jsCode": "const body = $('Webhook POST gastos-submit').first().json.body;\nconst SUPABASE = 'https://edjugpekcntzvqaskbmc.supabase.co/rest/v1';\nconst table = body.inmueble_tipo === 'piso' ? 'pisos' : 'habitaciones';\nconst url = `${SUPABASE}/${table}?id=eq.${body.inmueble_id}&select=id,id_inmueble,nombre,direccion_completa`;\nreturn [{ json: { url } }];"
      },
