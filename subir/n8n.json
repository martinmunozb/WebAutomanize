        {
            "id": "preparar-respuesta-get",
            "name": "Preparar Respuesta GET",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1340,
                200
            ],
            "parameters": {
                "jsCode": "const allItems = $input.all().map(i => i.json);\nconst clienteItem  = allItems.find(i => Array.isArray(i) ? i[0]?.nombre : i.nombre);\nconst inmuebleItem = allItems.find(i => Array.isArray(i) ? i[0]?.id_inmueble : i.id_inmueble);\nconst cliente  = Array.isArray(clienteItem)  ? clienteItem[0]  : clienteItem;\nconst inmueble = Array.isArray(inmuebleItem) ? inmuebleItem[0] : inmuebleItem;\nconst nombre     = cliente?.nombre || 'Inquilino';\nconst referencia = inmueble?.nombre ? `${inmueble.nombre} — ${inmueble.direccion_completa || ''}`.trim() : '';\nreturn [{ json: { nombre, referencia, ok: true } }];"
            }
        },
