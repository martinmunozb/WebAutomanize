      "parameters": {
        "jsCode": "const { from, replyId, replyTitle } = $('Switch Tipo Respuesta').first().json;\nconst to    = from.startsWith('+') ? from : '+' + from;\nconst token = $input.first().json.id || from;\nconst BASE  = 'https://automanize.com/subir/';\nconst urls  = {\n  'hipoteca':      `${BASE}?tipo=hipoteca&token=${token}`,\n  'seguro-vida':   `${BASE}?tipo=seguro-vida&token=${token}`,\n  'seguro-hogar':  `${BASE}?tipo=seguro-hogar&token=${token}`,\n  'seguro-impago': `${BASE}?tipo=seguro-impago&token=${token}`,\n  'comunidad':     `${BASE}?tipo=comunidad&token=${token}`,\n  'derramas':      `${BASE}?tipo=derramas&token=${token}`,\n  'ibi':           `${BASE}?tipo=ibi&token=${token}`,\n  'agua':          `${BASE}?tipo=agua&token=${token}`,\n  'luz':           `${BASE}?tipo=luz&token=${token}`,\n  'limpieza':      `${BASE}?tipo=limpieza&token=${token}`,\n  'alarma':        `${BASE}?tipo=alarma&token=${token}`,\n  'wifi':          `${BASE}?tipo=wifi&token=${token}`\n};\nconst uploadUrl = urls[replyId] || `${BASE}?tipo=otros&token=${token}`;\nconst body = { messaging_product: 'whatsapp', recipient_type: 'individual', to, type: 'text', text: { body: `✅ Has seleccionado: *${replyTitle}*\\n\\nSube el justificante de pago aquí:\\n\\n🔗 ${uploadUrl}` } };\nreturn [{ json: { from, requestBody: body } }];"
