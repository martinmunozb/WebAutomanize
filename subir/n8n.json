      "id": "a1000004-0004-0004-0004-000000000004",
      "name": "Buscar Inmueble",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [432, 1400]
    },
    {
      "parameters": {
        "jsCode": "const webhookItem = $('Webhook POST gastos-submit').first();\nconst body        = webhookItem.json.body;\nconst gestorData  = $('Validar Gestor').first().json;\nconst inmuebleData = $input.first().json;\n\nconst CARPETAS = {\n  'hipoteca':      '167rSr7ALC52FQz4NNtP4Yh33eBO0SgAN',\n  'seguro-vida':   '1bWe2D62QFgye0v5L5-ZnsLMmc88qVw9F',\n  'seguro-hogar':  '1IH6RrytwijxRYzrtBZzfnRqaFINDkF13',\n  'seguro-impago': '1vzIDLzJ5yrtg35NcViESA3V2EwlCp5O_',\n  'comunidad':     '1WgsRy0sKpcP9t45Mc-VDBY8y9x18vHl5',\n  'derramas':      '1RJsoEO-S3_be__UgsjR6CXSwRdVdzZP4',\n  'ibi':           '1jJUBl7OzilTTOJ8uJVQM04ryb03iMZkc',\n  'agua':          '1oSYS7AwF-l9l5Z8cO9GRLKX02R19LWli',\n  'luz':           '1gzCL7LAiCmhBaQbsUglt9F4xdFxhNWrD',\n  'limpieza':      '1z0yIN-83yHJBxLtBHMAu_ZVHqsDO5V2s',\n  'alarma':        '1-v5zouk7OuZeuDn7T6ialZL0vADjir3w',\n  'wifi':          '1-W05CTSlaErPraimwsFTJOI0Oc6pLX57'\n};\n\nconst tipo           = (body.tipo || 'otros').toLowerCase();\nconst carpetaRaizId  = CARPETAS[tipo] || '1i0iC9eoR-J1R69MLotuth-R1aHilbril';\n\nconst gestor         = Array.isArray(gestorData) ? gestorData[0] : gestorData;\nconst gestorId       = gestor?.id || body.gestor_id || body.token;\nconst gestorTelefono = gestor?.telefono || '';\n\nconst inmueble        = Array.isArray(inmuebleData) ? inmuebleData[0] : inmuebleData;\nconst nombreInmueble  = (inmueble?.nombre || body.inmueble_id || 'Inmueble').trim();\nconst inmuebleIdTexto = inmueble?.id_inmueble || body.inmueble_id;\n\nconst periodoRaw = body.periodo || '';\nconst MESES_ES   = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];\nlet mesAno = periodoRaw, periodoISO = '';\nif (periodoRaw.includes('-')) {\n  const parts  = periodoRaw.split('-');\n  const mesIdx = parseInt(parts[0], 10) - 1;\n  const ano    = parts[1];\n  mesAno      = `${MESES_ES[mesIdx] || parts[0]} ${ano}`;\n  periodoISO  = `${ano}-${parts[0].padStart(2, '0')}-01`;\n}\n\nconst binaryKey  = webhookItem.binary ? Object.keys(webhookItem.binary)[0] : 'archivo0';\nconst binaryData = webhookItem.binary?.[binaryKey];\nconst mimeType   = binaryData?.mimeType || 'image/jpeg';\nconst origName   = binaryData?.fileName || 'justificante.jpg';\nconst ext        = origName.split('.').pop() || 'jpg';\nconst nombreArchivo = `${tipo}-${periodoRaw}.${ext}`;\n\nreturn [{\n  json: {\n    gestorId, gestorTelefono,\n    inmuebleId:      body.inmueble_id,\n    inmuebleIdTexto: inmuebleIdTexto,\n    inmuebleTipo:    body.inmueble_tipo || 'habitacion',\n    tipo, periodoISO, periodoRaw, mesAno,\n    importe: parseFloat(body.importe) || 0,\n    carpetaRaizId, nombreInmueble, nombreArchivo, mimeType, binaryKey\n  },\n  binary: webhookItem.binary\n}];"
      },
