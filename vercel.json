{
  "rewrites": [
    { "source": "/subir/hipoteca",        "destination": "/subir/index.html?tipo=hipoteca" },
    { "source": "/subir/seguro-vida",     "destination": "/subir/index.html?tipo=seguro-vida" },
    { "source": "/subir/seguro-hogar",    "destination": "/subir/index.html?tipo=seguro-hogar" },
    { "source": "/subir/seguro-impago",   "destination": "/subir/index.html?tipo=seguro-impago" },
    { "source": "/subir/comunidad",       "destination": "/subir/index.html?tipo=comunidad" },
    { "source": "/subir/derramas",        "destination": "/subir/index.html?tipo=derramas" },
    { "source": "/subir/ibi",             "destination": "/subir/index.html?tipo=ibi" },
    { "source": "/subir/agua",            "destination": "/subir/index.html?tipo=agua" },
    { "source": "/subir/luz",             "destination": "/subir/index.html?tipo=luz" },
    { "source": "/subir/limpieza",        "destination": "/subir/index.html?tipo=limpieza" },
    { "source": "/subir/alarma",          "destination": "/subir/index.html?tipo=alarma" },
    { "source": "/subir/wifi",            "destination": "/subir/index.html?tipo=wifi" }
  ],
  "redirects": [
    {
      "source": "/privacy.html",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/terms.html",
      "destination": "/index.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://assets.calendly.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://n8n.automanize.com https://calendly.com https://assets.calendly.com https://www.googletagmanager.com https://www.google-analytics.com; frame-src https://calendly.com; object-src 'none'; base-uri 'self'; form-action 'self' https://n8n.automanize.com; frame-ancestors 'none'; upgrade-insecure-requests"
        }
      ]
    }
  ]
}
